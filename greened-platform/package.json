{
  "name": "greened-platform",
  "private": true,
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "install-all": "npm --workspace=server install && npm --workspace=client install",
    "dev": "concurrently \"npm --workspace=server run dev\" \"npm --workspace=client run dev\"",
    "build": "npm --workspace=client run build",
    "test": "npm --workspace=server test"
  },
  "devDependencies": {
    "concurrently": "^8.0.0"
  }
}